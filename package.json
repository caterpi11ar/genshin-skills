{
  "name": "genshin-auto",
  "version": "0.2.0",
  "description": "AI vision-driven Genshin Impact cloud gaming automation",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "genshin-auto": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/web/public dist/web/public",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "start:daemon": "node dist/cli.js daemon",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "@midscene/web": "^1.5.0",
    "@playwright/test": "^1.58.2",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "ink": "^4.4.0",
    "node-cron": "^3.0.0",
    "playwright": "^1.52.0",
    "react": "^18.3.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/node-cron": "^3.0.0",
    "@types/react": "^18.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
