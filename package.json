{
  "name": "giclaw",
  "version": "0.3.0",
  "description": "AI agent for Genshin Impact cloud gaming",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/caterpi11ar/giclaw.git"
  },
  "homepage": "https://giclaw.cn",
  "keywords": [
    "genshin-impact",
    "ai-agent",
    "cloud-gaming",
    "automation",
    "playwright"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "giclaw": "dist/cli.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc && cp -r src/web/public dist/web/public",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "start:daemon": "node dist/cli.js daemon",
    "test": "vitest run",
    "docs:dev": "pnpm --dir docs start",
    "docs:build": "pnpm --dir docs build",
    "docs:serve": "pnpm --dir docs serve"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "@inquirer/prompts": "^8.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "gray-matter": "^4.0.3",
    "ink": "^4.4.0",
    "node-cron": "^3.0.0",
    "playwright": "^1.52.0",
    "react": "^18.3.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/node-cron": "^3.0.0",
    "@types/react": "^18.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
